---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { firstNonEmptyLine } from "@/lib/wizard/exporter";
import { DecisionDetail } from "@/components/artifact/DecisionDetail";
import type { Decision } from "@/types";

const { id } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);
let decision: Decision | null = null;
let loadError = false;
if (supabase && id) {
  const { data, error } = await supabase.from("decisions").select("*").eq("id", id).maybeSingle<Decision>();
  if (error) {
    loadError = true;
  } else {
    decision = data ?? null;
  }
}

if (loadError) {
  Astro.response.status = 500;
} else if (!decision) {
  Astro.response.status = 404;
}

const title = decision ? firstNonEmptyLine(decision.description) || "Untitled" : "";
---

<Layout title={decision ? `Decision: ${title}` : loadError ? "Error" : "Not found"}>
  <div class="bg-cosmic min-h-screen p-4 text-white">
    <div class="mx-auto max-w-2xl space-y-5 py-8">
      <a
        href="/dashboard"
        class="inline-flex items-center gap-1 text-sm text-blue-100/70 transition-colors hover:text-white"
      >
        ← Back to decisions
      </a>

      {
        decision ? (
          <DecisionDetail title={title} decision={decision} client:only="react" />
        ) : loadError ? (
          <div class="rounded-2xl border border-rose-400/30 bg-rose-500/10 p-10 text-center backdrop-blur-xl">
            <p class="text-lg font-medium text-white/90">Couldn't load this decision</p>
            <p class="mt-1 text-sm text-blue-100/60">Something went wrong on our end. Please try again.</p>
          </div>
        ) : (
          <div class="rounded-2xl border border-white/10 bg-white/5 p-10 text-center backdrop-blur-xl">
            <p class="text-lg font-medium text-white/90">Decision not found</p>
            <p class="mt-1 text-sm text-blue-100/60">It may have been removed, or the link is incorrect.</p>
          </div>
        )
      }
    </div>
  </div>
</Layout>
