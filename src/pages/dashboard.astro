---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { firstNonEmptyLine } from "@/lib/wizard/exporter";

const { user } = Astro.locals;

interface DecisionRow {
  id: string;
  description: string;
  summary: string;
  created_at: string;
}

const supabase = createClient(Astro.request.headers, Astro.cookies);
let decisions: DecisionRow[] = [];
let loadError = false;
if (supabase) {
  const { data, error } = await supabase
    .from("decisions")
    .select("id, description, summary, created_at")
    .order("created_at", { ascending: false })
    .overrideTypes<DecisionRow[], { merge: false }>();
  if (error) {
    loadError = true;
  } else {
    decisions = data;
  }
}

const dateFmt = new Intl.DateTimeFormat("en", { year: "numeric", month: "short", day: "numeric" });
---

<Layout title="Your decisions">
  <div class="bg-cosmic min-h-screen p-4 text-white">
    <div class="mx-auto max-w-2xl space-y-6 py-8">
      <header class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
            Your decisions
          </h1>
          <p class="mt-1 text-sm text-blue-100/60">{user?.email}</p>
        </div>
        <div class="flex items-center gap-2">
          <a
            href="/decisions/new"
            class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
          >
            New decision
          </a>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
            >
              Sign out
            </button>
          </form>
        </div>
      </header>

      {
        loadError ? (
          <div class="rounded-2xl border border-rose-400/30 bg-rose-500/10 p-10 text-center backdrop-blur-xl">
            <p class="text-lg font-medium text-white/90">Couldn't load your decisions</p>
            <p class="mt-1 text-sm text-blue-100/60">Something went wrong on our end. Please refresh to try again.</p>
          </div>
        ) : decisions.length === 0 ? (
          <div class="rounded-2xl border border-white/10 bg-white/5 p-10 text-center backdrop-blur-xl">
            <p class="text-lg font-medium text-white/90">No decisions yet</p>
            <p class="mt-1 text-sm text-blue-100/60">Walk a decision through the wizard and it'll be saved here.</p>
            <a
              href="/decisions/new"
              class="mt-6 inline-block rounded-lg bg-gradient-to-r from-blue-500 to-purple-500 px-5 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90"
            >
              Start your first decision
            </a>
          </div>
        ) : (
          <ul class="space-y-3">
            {decisions.map((d) => (
              <li>
                <a
                  href={`/decisions/${d.id}`}
                  class="block space-y-1.5 rounded-xl border border-white/10 bg-white/5 p-4 transition-colors hover:bg-white/10"
                >
                  <h2 class="leading-snug font-semibold text-white">
                    {firstNonEmptyLine(d.description) || "Untitled"}
                  </h2>
                  {d.summary ? <p class="text-sm text-white/70">{d.summary}</p> : null}
                  <p class="text-xs text-white/40">{dateFmt.format(new Date(d.created_at))}</p>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</Layout>
